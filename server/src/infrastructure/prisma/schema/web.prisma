model Web {
  id             Int             @id() @default(autoincrement())
  name           String
  alias          String          @unique
  url            String
  agendas        Agenda[]
  projects       Project[]
  news           News[]
  zones          Zone[]
  exhibitions    Exhibition[]
  exhibitors     Exhibitor[]
  conferences    Conferences[]
  exhibitorRanks ExhibitorRank[]
  booths         Booth[]

  @@map("webs")
}
